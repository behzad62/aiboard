/coverage
/test-results/
/playwright-report/

# default --out for scripts/probe-toolreliability-pack.mts / probe-gameiq-pack.mts
# style live probes (model prompts/responses, never meant to be committed)
/probe-runs/

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
.vs/
.playwright-mcp/
.codex-run-logs/
.superpowers/
.worktrees/
docs/superpowers/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env*.local
.env

# database and local uploads
/data/

# build-time copy of scripts/runner.mjs (the downloadable runner) + its manifest
/public/runner.mjs
/public/runner-manifest.json
/public/account-provider-runner.mjs
/public/bench-runner.mjs

# typescript
*.tsbuildinfo
next-env.d.ts

# drizzle
/drizzle

# Ed25519 private key for signing runner self-updates (never commit)
/scripts/.runner-signing-key.pem
